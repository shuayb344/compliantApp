rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if the user is an admin
    function isAdmin() {
      return isAuth() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // User profile rules
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }
    
    // Complaint rules
    match /complaints/{complaintId} {
      allow read: if isAuth() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAuth() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
      
      // Discussion messages subcollection
      match /messages/{messageId} {
        allow read: if isAuth() && (isAdmin() || get(/databases/$(database)/documents/complaints/$(complaintId)).data.userId == request.auth.uid);
        allow create: if isAuth();
      }
    }
    
    // Notification rules
    match /notifications/{notificationId} {
      allow read: if isAuth() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth(); // Allow server/admin to create notifications
    }
  }
}
